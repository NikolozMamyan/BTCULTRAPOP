<section class="max-w-7xl mx-auto px-5 mt-16 reveal">
    <div class="relative rounded-lg-c overflow-hidden bg-gradient-to-r from-primary to-primary-d text-white p-8 md:p-10 flex flex-col md:flex-row items-center justify-between gap-6">
        <div class="blob bg-secondary/40 w-72 h-72 -top-24 -right-10"></div>
        <div class="relative z-10 text-center md:text-left">
            <span class="text-xs font-bold tracking-widest uppercase bg-white/20 px-3 py-1 rounded-full"><i class="fa-solid fa-bolt mr-1"></i>{{ 'home.flash.badge'|trans }}</span>
            <h2 class="font-display text-3xl md:text-4xl font-extrabold mt-3">{{ 'home.flash.title'|trans }}</h2>
        </div>
        <div class="relative z-10 flex gap-3">
            <div class="bg-white/15 backdrop-blur rounded-md-c w-16 py-3 text-center"><span id="cd-h" class="font-display text-2xl font-extrabold block">00</span><span class="text-[10px] uppercase opacity-70">{{ 'home.flash.hours'|trans }}</span></div>
            <div class="bg-white/15 backdrop-blur rounded-md-c w-16 py-3 text-center"><span id="cd-m" class="font-display text-2xl font-extrabold block">00</span><span class="text-[10px] uppercase opacity-70">{{ 'home.flash.minutes'|trans }}</span></div>
            <div class="bg-white/15 backdrop-blur rounded-md-c w-16 py-3 text-center"><span id="cd-s" class="font-display text-2xl font-extrabold block">00</span><span class="text-[10px] uppercase opacity-70">{{ 'home.flash.seconds'|trans }}</span></div>
        </div>
    </div>
</section>
