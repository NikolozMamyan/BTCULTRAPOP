<section class="max-w-7xl mx-auto px-5 mt-10">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="s-rise d1 bg-bg-light rounded-md-c p-5 flex items-center gap-4 border border-border-c">
            <div class="w-11 h-11 rounded-full bg-primary/10 text-primary flex items-center justify-center text-lg shrink-0"><i class="fa-solid fa-truck-fast"></i></div>
            <div><p class="font-bold text-sm">{{ 'home.service.fast_delivery'|trans }}</p><p class="text-text-light text-xs">{{ 'home.service.fast_delivery_text'|trans }}</p></div>
        </div>
        <div class="s-rise d2 bg-bg-light rounded-md-c p-5 flex items-center gap-4 border border-border-c">
            <div class="w-11 h-11 rounded-full bg-secondary/20 text-text-dark flex items-center justify-center text-lg shrink-0"><i class="fa-solid fa-clapperboard"></i></div>
            <div><p class="font-bold text-sm">{{ 'home.service.official_licenses'|trans }}</p><p class="text-text-light text-xs">{{ 'home.service.official_licenses_text'|trans }}</p></div>
        </div>
        <div class="s-rise d3 bg-bg-light rounded-md-c p-5 flex items-center gap-4 border border-border-c">
            <div class="w-11 h-11 rounded-full bg-success/10 text-success flex items-center justify-center text-lg shrink-0"><i class="fa-solid fa-lock"></i></div>
            <div><p class="font-bold text-sm">{{ 'home.service.secure_payment'|trans }}</p><p class="text-text-light text-xs">{{ 'home.service.secure_payment_text'|trans }}</p></div>
        </div>
        <div class="s-rise d4 bg-bg-light rounded-md-c p-5 flex items-center gap-4 border border-border-c">
            <div class="w-11 h-11 rounded-full bg-primary/10 text-primary flex items-center justify-center text-lg shrink-0"><i class="fa-solid fa-headset"></i></div>
            <div><p class="font-bold text-sm">{{ 'home.service.support'|trans }}</p><p class="text-text-light text-xs">{{ 'home.service.support_text'|trans }}</p></div>
        </div>
    </div>
</section>
