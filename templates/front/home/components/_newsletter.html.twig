<section id="newsletter" class="max-w-7xl mx-auto px-5 mt-20 reveal">
    <div
        class="home-newsletter-card relative rounded-lg-c overflow-hidden text-white p-6 md:p-14 text-center"
        style="--newsletter-background: url('{{ asset('img/home/newsletter.jpg') }}')"
    >
        <div class="home-newsletter-card__content relative z-10 max-w-xl mx-auto">
            <h2 class="font-display text-2xl md:text-4xl font-extrabold mb-3">{{ 'home.newsletter.title'|trans }}</h2>
            <p class="text-white/70 mb-7 text-sm md:text-base">{{ 'home.newsletter.text'|trans }}</p>
            <div
                data-controller="newsletter"
                data-newsletter-error-value="{{ 'newsletter.flash.error'|trans }}"
            >
                <form
                    action="{{ path('app_newsletter_subscribe') }}"
                    method="post"
                    class="newsletter-form flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
                    data-action="submit->newsletter#submit"
                    data-newsletter-target="form"
                >
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('newsletter_subscribe') }}">
                    <input type="hidden" name="source" value="home">
                    <input type="hidden" name="redirect" value="{{ path('app_front_home') }}#newsletter">
                    <label for="home-newsletter-email" class="sr-only">{{ 'common.email'|trans }}</label>
                    <input id="home-newsletter-email" name="email" type="email" required autocomplete="email" placeholder="{{ 'home.newsletter.placeholder'|trans }}" class="flex-1 px-5 py-3.5 rounded-full text-text-dark outline-none text-sm" data-newsletter-target="email">
                    <button type="submit" class="bg-primary hover:bg-primary-d px-7 py-3.5 rounded-full font-bold text-sm transition-colors shrink-0" data-newsletter-target="button">{{ 'home.newsletter.subscribe'|trans }}</button>
                </form>
                <div class="newsletter-feedback newsletter-feedback--centered" data-newsletter-target="message" role="status" aria-live="polite" aria-atomic="true" hidden style="display:none">
                    <i class="fa-solid fa-circle-check" data-newsletter-target="messageIcon"></i>
                    <span data-newsletter-target="messageText"></span>
                </div>
            </div>
        </div>
    </div>
</section>
