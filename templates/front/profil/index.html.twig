{% extends 'front/base.html.twig' %}

{% block title %}{{ 'page.profile.title'|trans }}{% endblock %}
{% block storefront_data %}data-page="profile"{% endblock %}

{% block main %}
    <section class="profile-hero">
        <div class="max-w-7xl mx-auto px-5 py-8 md:py-10">
            <p class="text-xs text-text-light font-semibold mb-2">
                <a href="{{ path('app_front_home') }}" class="hover:text-primary">{{ 'common.home'|trans }}</a>
                <i class="fa-solid fa-chevron-right text-[8px] mx-2"></i>
                {{ 'common.profile'|trans }}
            </p>
            <h1 class="font-display text-3xl md:text-4xl font-extrabold">{{ 'profile.title'|trans }}</h1>
            <p class="text-text-light text-sm mt-2">{{ 'profile.intro'|trans }}</p>
        </div>
    </section>

    <section class="profile-page max-w-5xl mx-auto px-5 py-10 md:py-16">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="profile-flash profile-flash--{{ type }}">
                    <i class="fa-solid {{ type == 'success' ? 'fa-circle-check' : 'fa-triangle-exclamation' }}"></i>
                    <span>{{ message|trans }}</span>
                </div>
            {% endfor %}
        {% endfor %}

        {% if app.user %}
            <article class="profile-card">
                <div class="profile-card__header">
                    <form
                        class="profile-avatar-upload"
                        action="{{ path('app_front_profile_avatar_upload') }}"
                        method="post"
                        enctype="multipart/form-data"
                        data-controller="avatar-upload"
                    >
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile_avatar_upload') }}">
                        <label class="profile-card__avatar" for="profile-avatar-input">
                            {% if app.user.avatarPath %}
                                <img src="{{ asset(app.user.avatarPath) }}" alt="{{ 'profile.avatar.current'|trans }}" data-avatar-upload-target="preview">
                                <span class="profile-card__avatar-fallback is-hidden" data-avatar-upload-target="fallback">
                                    <i class="fa-solid fa-user"></i>
                                </span>
                            {% else %}
                                <img class="is-hidden" src="" alt="{{ 'profile.avatar.preview'|trans }}" data-avatar-upload-target="preview">
                                <span class="profile-card__avatar-fallback" data-avatar-upload-target="fallback">
                                    <i class="fa-solid fa-user"></i>
                                </span>
                            {% endif %}
                            <span class="profile-avatar-upload__button" aria-hidden="true">
                                <i class="fa-solid fa-camera"></i>
                            </span>
                            <span class="sr-only">{{ 'profile.avatar.upload'|trans }}</span>
                        </label>
                        <input
                            id="profile-avatar-input"
                            class="sr-only"
                            type="file"
                            name="avatar"
                            accept="image/jpeg,image/png,image/webp"
                            data-avatar-upload-target="input"
                            data-action="avatar-upload#submit"
                        >
                    </form>
                    <div>
                        <span class="profile-card__eyebrow">{{ 'profile.account'|trans }}</span>
                        <h2>{{ 'profile.information'|trans }}</h2>
                        <p>{{ app.user.fullName ?: user_identifier ?: 'profile.complete'|trans }}</p>
                    </div>
                    <span class="profile-card__points" aria-label="{{ 'profile.points_label'|trans({'%count%': app.user.loyaltyPoints}) }}">
                        <i class="fa-solid fa-star"></i>
                        <strong>{{ app.user.loyaltyPoints }}</strong>
                        <span>{{ 'profile.points'|trans }}</span>
                    </span>
                    <form action="{{ path('app_auth_logout') }}" method="post" class="profile-card__logout">
                        <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth_logout') }}">
                        <button type="submit">
                            <i class="fa-solid fa-right-from-bracket"></i>
                            {{ 'auth.logout.submit'|trans }}
                        </button>
                    </form>
                </div>

                <div class="profile-card__details">
                    <div class="profile-detail">
                        <span class="profile-detail__icon"><i class="fa-regular fa-user"></i></span>
                        <div>
                            <span>{{ 'common.full_name'|trans }}</span>
                            <strong>{{ app.user.fullName ?: 'profile.not_provided'|trans }}</strong>
                        </div>
                    </div>
                    <div class="profile-detail">
                        <span class="profile-detail__icon"><i class="fa-regular fa-envelope"></i></span>
                        <div>
                            <span>{{ 'common.email'|trans }}</span>
                            <strong>{{ app.user.email }}</strong>
                        </div>
                    </div>
                    <div class="profile-detail profile-detail--address">
                        <span class="profile-detail__icon"><i class="fa-solid fa-location-dot"></i></span>
                        <div>
                            <span>{{ 'profile.shipping_address'|trans }}</span>
                            {% set default_address = app.user.defaultAddress %}
                            {% if default_address %}
                                <strong>{{ default_address.name }} · {{ default_address.street }}, {{ default_address.postalCode }} {{ default_address.city }}</strong>
                            {% else %}
                                <strong>{{ 'profile.no_address'|trans }}</strong>
                            {% endif %}
                        </div>
                    </div>
                </div>

                <section class="profile-addresses" aria-labelledby="profile-addresses-title">
                    <div class="profile-addresses__heading">
                        <div>
                            <span class="profile-card__eyebrow">{{ 'profile.addresses_eyebrow'|trans }}</span>
                            <h3 id="profile-addresses-title">{{ 'profile.addresses_title'|trans }}</h3>
                            <p>{{ 'profile.addresses_text'|trans }}</p>
                        </div>
                    </div>

                    <div class="profile-addresses__list">
                        {% for address in app.user.addresses %}
                            <details class="profile-address-card">
                                <summary class="profile-address-card__summary">
                                    <span class="profile-address-card__icon">
                                        <i class="fa-solid fa-location-dot"></i>
                                    </span>
                                    <span class="profile-address-card__content">
                                        <strong class="profile-address-card__name">{{ address.name }}</strong>
                                        <span class="profile-address-card__line">{{ address.street }}</span>
                                        <span class="profile-address-card__meta">{{ address.postalCode }} {{ address.city }}{% if address.phone %} · {{ address.phone }}{% endif %}</span>
                                    </span>
                                    <span class="profile-address-card__badges">
                                        {% if address.defaultAddress %}
                                            <em>{{ 'profile.address.default'|trans }}</em>
                                        {% endif %}
                                    </span>
                                    <span class="profile-address-card__edit" title="{{ 'profile.address.edit'|trans }}">
                                        <i class="fa-solid fa-pen"></i>
                                        <span class="sr-only">{{ 'profile.address.edit'|trans }}</span>
                                    </span>
                                </summary>

                                <form class="profile-address-form profile-address-form--edit" action="{{ path('app_front_profile_address_update', {id: address.id}) }}" method="post">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile_address_update_' ~ address.id) }}">
                                    <input type="hidden" name="country_code" value="{{ address.countryCode }}">

                                    <div class="profile-address-form__grid">
                                        <label class="profile-address-form__field">
                                            <span>{{ 'common.address_name'|trans }}</span>
                                            <input type="text" name="address_name" value="{{ address.name }}" placeholder="{{ 'auth.register.address_name_placeholder'|trans }}">
                                        </label>
                                        <label class="profile-address-form__field">
                                            <span>{{ 'common.street'|trans }}</span>
                                            <input type="text" name="street" value="{{ address.street }}" autocomplete="street-address" required>
                                        </label>
                                        <label class="profile-address-form__field">
                                            <span>{{ 'common.postal_code'|trans }}</span>
                                            <input type="text" name="postal_code" value="{{ address.postalCode }}" autocomplete="postal-code" inputmode="numeric" required>
                                        </label>
                                        <label class="profile-address-form__field">
                                            <span>{{ 'common.city'|trans }}</span>
                                            <input type="text" name="city" value="{{ address.city }}" autocomplete="address-level2" required>
                                        </label>
                                        <label class="profile-address-form__field">
                                            <span>{{ 'common.phone'|trans }}</span>
                                            <input type="tel" name="phone" value="{{ address.phone }}" autocomplete="tel">
                                        </label>
                                    </div>

                                    <div class="profile-address-form__actions">
                                        <label class="profile-address-form__check">
                                            <input type="checkbox" name="default_address" value="1" {{ address.defaultAddress ? 'checked' : '' }}>
                                            <span>{{ 'profile.address.set_default'|trans }}</span>
                                        </label>
                                        <button type="submit">
                                            <i class="fa-solid fa-floppy-disk"></i>
                                            {{ 'profile.address.save'|trans }}
                                        </button>
                                    </div>
                                </form>
                            </details>
                        {% else %}
                            <p class="profile-addresses__empty">{{ 'profile.no_address'|trans }}</p>
                        {% endfor %}
                    </div>

                    <details class="profile-address-add">
                        <summary>
                            <span><i class="fa-solid fa-plus"></i> {{ 'profile.address.add'|trans }}</span>
                            <i class="fa-solid fa-chevron-down"></i>
                        </summary>
                        <form class="profile-address-form profile-address-form--new" action="{{ path('app_front_profile_address_add') }}" method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('profile_address_add') }}">
                            <input type="hidden" name="country_code" value="FR">

                            <div class="profile-address-form__grid">
                                <label class="profile-address-form__field">
                                    <span>{{ 'common.address_name'|trans }}</span>
                                    <input type="text" name="address_name" placeholder="{{ 'auth.register.address_name_placeholder'|trans }}">
                                </label>
                                <label class="profile-address-form__field">
                                    <span>{{ 'common.street'|trans }}</span>
                                    <input type="text" name="street" autocomplete="street-address" required>
                                </label>
                                <label class="profile-address-form__field">
                                    <span>{{ 'common.postal_code'|trans }}</span>
                                    <input type="text" name="postal_code" autocomplete="postal-code" inputmode="numeric" required>
                                </label>
                                <label class="profile-address-form__field">
                                    <span>{{ 'common.city'|trans }}</span>
                                    <input type="text" name="city" autocomplete="address-level2" required>
                                </label>
                                <label class="profile-address-form__field">
                                    <span>{{ 'common.phone'|trans }}</span>
                                    <input type="tel" name="phone" autocomplete="tel">
                                </label>
                            </div>

                            <div class="profile-address-form__actions">
                                <label class="profile-address-form__check">
                                    <input type="checkbox" name="default_address" value="1">
                                    <span>{{ 'profile.address.set_default'|trans }}</span>
                                </label>
                                <button type="submit">
                                    <i class="fa-solid fa-plus"></i>
                                    {{ 'profile.address.add_submit'|trans }}
                                </button>
                            </div>
                        </form>
                    </details>
                </section>
            </article>
        {% else %}
            <div class="profile-auth" data-controller="profile-auth">
                <div class="profile-auth__card" data-profile-auth-target="card">
                    <article class="profile-auth__face profile-auth__face--login" data-profile-auth-target="login">
                        <div class="profile-auth__heading">
                            <span class="profile-auth__icon"><i class="fa-solid fa-right-to-bracket"></i></span>
                            <div>
                                <span class="profile-card__eyebrow">{{ 'auth.login.eyebrow'|trans }}</span>
                                <h2>{{ 'auth.login.title'|trans }}</h2>
                                <p>{{ 'auth.login.text'|trans }}</p>
                            </div>
                        </div>

                        <form class="profile-auth__form" action="{{ path('app_auth_login') }}" method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth_login') }}">
                            <label class="profile-auth__field">
                                <span>{{ 'common.email'|trans }}</span>
                                <span class="profile-auth__input">
                                    <i class="fa-regular fa-envelope"></i>
                                    <input type="email" name="email" autocomplete="email" required placeholder="email@example.com">
                                </span>
                            </label>
                            <label class="profile-auth__field">
                                <span>{{ 'common.password'|trans }}</span>
                                <span class="profile-auth__input">
                                    <i class="fa-solid fa-lock"></i>
                                    <input type="password" name="password" autocomplete="current-password" required placeholder="••••••••">
                                </span>
                            </label>
                            <button type="submit" class="profile-auth__submit">
                                {{ 'auth.login.submit'|trans }}
                                <i class="fa-solid fa-arrow-right"></i>
                            </button>
                        </form>

                        <p class="profile-auth__switch">
                            {{ 'auth.login.no_account'|trans }}
                            <button type="button" data-action="profile-auth#showRegister">{{ 'auth.login.register'|trans }}</button>
                        </p>
                    </article>

                    <article class="profile-auth__face profile-auth__face--register" data-profile-auth-target="register">
                        <div class="profile-auth__heading">
                            <span class="profile-auth__icon profile-auth__icon--register"><i class="fa-solid fa-user-plus"></i></span>
                            <div>
                                <span class="profile-card__eyebrow">{{ 'auth.register.eyebrow'|trans }}</span>
                                <h2>{{ 'auth.register.title'|trans }}</h2>
                                <p>{{ 'auth.register.text'|trans }}</p>
                            </div>
                        </div>

                        <form class="profile-auth__form" action="{{ path('app_auth_register') }}" method="post">
                            <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth_register') }}">
                            <div class="profile-auth__grid">
                                <label class="profile-auth__field">
                                    <span>{{ 'common.last_name'|trans }}</span>
                                    <span class="profile-auth__input">
                                        <i class="fa-regular fa-id-card"></i>
                                        <input type="text" name="last_name" autocomplete="family-name" required>
                                    </span>
                                </label>
                                <label class="profile-auth__field">
                                    <span>{{ 'common.first_name'|trans }}</span>
                                    <span class="profile-auth__input">
                                        <i class="fa-regular fa-user"></i>
                                        <input type="text" name="first_name" autocomplete="given-name" required>
                                    </span>
                                </label>
                            </div>
                            <label class="profile-auth__field">
                                <span>{{ 'common.email'|trans }}</span>
                                <span class="profile-auth__input">
                                    <i class="fa-regular fa-envelope"></i>
                                    <input type="email" name="email" autocomplete="email" required placeholder="email@example.com">
                                </span>
                            </label>
                            <label class="profile-auth__field">
                                <span>{{ 'common.password'|trans }}</span>
                                <span class="profile-auth__input">
                                    <i class="fa-solid fa-lock"></i>
                                    <input type="password" name="password" autocomplete="new-password" minlength="8" required placeholder="••••••••">
                                </span>
                            </label>
                            <fieldset class="profile-auth__address">
                                <legend>{{ 'auth.register.shipping_address'|trans }}</legend>
                                <label class="profile-auth__field">
                                    <span>{{ 'common.address_name'|trans }}</span>
                                    <span class="profile-auth__input">
                                        <i class="fa-solid fa-house"></i>
                                        <input type="text" name="address_name" autocomplete="off" placeholder="{{ 'auth.register.address_name_placeholder'|trans }}">
                                    </span>
                                </label>
                                <label class="profile-auth__field">
                                    <span>{{ 'common.street'|trans }}</span>
                                    <span class="profile-auth__input">
                                        <i class="fa-solid fa-road"></i>
                                        <input type="text" name="street" autocomplete="street-address" required>
                                    </span>
                                </label>
                                <div class="profile-auth__grid profile-auth__grid--address">
                                    <label class="profile-auth__field">
                                        <span>{{ 'common.postal_code'|trans }}</span>
                                        <span class="profile-auth__input">
                                            <i class="fa-solid fa-location-crosshairs"></i>
                                            <input type="text" name="postal_code" autocomplete="postal-code" inputmode="numeric" required>
                                        </span>
                                    </label>
                                    <label class="profile-auth__field">
                                        <span>{{ 'common.city'|trans }}</span>
                                        <span class="profile-auth__input">
                                            <i class="fa-solid fa-city"></i>
                                            <input type="text" name="city" autocomplete="address-level2" required>
                                        </span>
                                    </label>
                                </div>
                            </fieldset>
                            <button type="submit" class="profile-auth__submit">
                                {{ 'auth.register.submit'|trans }}
                                <i class="fa-solid fa-user-plus"></i>
                            </button>
                        </form>

                        <p class="profile-auth__switch">
                            {{ 'auth.register.has_account'|trans }}
                            <button type="button" data-action="profile-auth#showLogin">{{ 'auth.register.login'|trans }}</button>
                        </p>
                    </article>
                </div>
            </div>
        {% endif %}

        <article
            class="language-card"
            aria-labelledby="language-title"
            data-controller="language"
            data-language-current-value="{{ app.request.locale }}"
        >
            <div class="language-card__heading">
                <span class="language-card__icon"><i class="fa-solid fa-language"></i></span>
                <div>
                    <span class="profile-card__eyebrow">{{ 'profile.preferences'|trans }}</span>
                    <h2 id="language-title">{{ 'profile.language_title'|trans }}</h2>
                    <p>{{ 'profile.language_text'|trans }}</p>
                </div>
            </div>

            <div class="language-selector" role="group" aria-label="{{ 'profile.language_label'|trans }}">
                <button
                    type="button"
                    class="language-option {{ app.request.locale == 'fr' ? 'is-active' : '' }}"
                    data-action="language#select"
                    data-language-locale-param="fr"
                    aria-pressed="{{ app.request.locale == 'fr' ? 'true' : 'false' }}"
                >
                    <span class="language-option__flag">
                        <img src="{{ asset('img/languages/fr.svg') }}" alt="" aria-hidden="true">
                    </span>
                    <span class="language-option__label">
                        <strong>{{ 'profile.french'|trans }}</strong>
                        <small>{{ 'profile.france'|trans }}</small>
                    </span>
                    <span class="language-option__check"><i class="fa-solid fa-check"></i></span>
                </button>
                <button
                    type="button"
                    class="language-option {{ app.request.locale == 'en' ? 'is-active' : '' }}"
                    data-action="language#select"
                    data-language-locale-param="en"
                    aria-pressed="{{ app.request.locale == 'en' ? 'true' : 'false' }}"
                >
                    <span class="language-option__flag">
                        <img src="{{ asset('img/languages/gb.svg') }}" alt="" aria-hidden="true">
                    </span>
                    <span class="language-option__label">
                        <strong>{{ 'profile.english'|trans }}</strong>
                        <small>{{ 'profile.international'|trans }}</small>
                    </span>
                    <span class="language-option__check"><i class="fa-solid fa-check"></i></span>
                </button>
            </div>
            <p class="language-card__notice"><i class="fa-solid fa-cookie-bite"></i> {{ 'profile.language_notice'|trans }}</p>
        </article>
    </section>
{% endblock %}
