{% extends 'front/base.html.twig' %}

{% block title %}{% block information_meta_title %}Informations | ULTRAPOP{% endblock %}{% endblock %}
{% block meta_description %}{% block information_meta_description %}Informations utiles et légales concernant la boutique ULTRAPOP.{% endblock %}{% endblock %}
{% block canonical_url %}{% block information_canonical %}{{ seo_origin ~ app.request.pathInfo }}{% endblock %}{% endblock %}
{% block storefront_data %}data-page="information"{% endblock %}

{% block main %}
    {% set current_route = app.request.attributes.get('_route') %}
    <header class="information-hero">
        <div class="information-hero__glow information-hero__glow--one"></div>
        <div class="information-hero__glow information-hero__glow--two"></div>
        <div class="information-hero__content max-w-7xl mx-auto px-5">
            <nav class="information-breadcrumb" aria-label="Fil d’Ariane">
                <a href="{{ path('app_front_home') }}">{{ 'common.home'|trans }}</a>
                <i class="fa-solid fa-chevron-right"></i>
                <span>{% block information_breadcrumb %}Informations{% endblock %}</span>
            </nav>
            <span class="information-hero__icon">
                <i class="{% block information_icon %}fa-solid fa-circle-info{% endblock %}"></i>
            </span>
            <p class="information-hero__eyebrow">{% block information_eyebrow %}ULTRAPOP vous informe{% endblock %}</p>
            <h1>{% block information_title %}Informations{% endblock %}</h1>
            <p class="information-hero__intro">{% block information_intro %}{% endblock %}</p>
        </div>
    </header>

    <div class="information-layout max-w-7xl mx-auto px-5">
        <aside class="information-nav" aria-label="Pages d’information">
            <p>Informations</p>
            <nav>
                <a href="{{ path('app_front_delivery') }}" class="{{ current_route == 'app_front_delivery' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-truck-fast"></i>
                    Livraison
                </a>
                <a href="{{ path('app_front_returns') }}" class="{{ current_route == 'app_front_returns' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-rotate-left"></i>
                    Retours et rétractation
                </a>
                <a href="{{ path('app_front_terms') }}" class="{{ current_route == 'app_front_terms' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-file-contract"></i>
                    Conditions de vente
                </a>
                <a href="{{ path('app_front_legal') }}" class="{{ current_route == 'app_front_legal' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-scale-balanced"></i>
                    Mentions légales
                </a>
                <a href="{{ path('app_front_privacy') }}" class="{{ current_route == 'app_front_privacy' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-shield-halved"></i>
                    Confidentialité
                </a>
                <a href="{{ path('app_front_contact') }}" class="{{ current_route == 'app_front_contact' ? 'is-active' : '' }}">
                    <i class="fa-solid fa-envelope"></i>
                    Contact
                </a>
            </nav>
        </aside>

        <article class="information-card">
            {% block information_content %}{% endblock %}
        </article>
    </div>
{% endblock %}
