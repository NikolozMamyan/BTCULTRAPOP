{% extends 'front/base.html.twig' %}

{% block title %}{{ 'auth.reset.new_title'|trans }} | ULTRAPOP{% endblock %}
{% block meta_description %}{{ 'auth.reset.new_meta_description'|trans }}{% endblock %}
{% block storefront_data %}data-page="auth-reset"{% endblock %}

{% block main %}
    <section class="auth-reset-page">
        <div class="auth-reset-shell max-w-5xl mx-auto px-5">
            <article class="auth-reset-card">
                <div class="auth-reset-card__icon auth-reset-card__icon--success">
                    <i class="fa-solid fa-shield-halved"></i>
                </div>

                <p class="auth-reset-card__eyebrow">{{ 'auth.reset.new_eyebrow'|trans }}</p>
                <h1>{{ 'auth.reset.new_title'|trans }}</h1>
                <p>{{ 'auth.reset.new_text'|trans }}</p>

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="profile-flash profile-flash--{{ type }}">
                            <i class="fa-solid {{ type == 'success' ? 'fa-circle-check' : 'fa-triangle-exclamation' }}"></i>
                            <span>{{ message|trans }}</span>
                        </div>
                    {% endfor %}
                {% endfor %}

                <form class="auth-reset-form" action="{{ path('app_auth_reset_password_submit', {token: token}) }}" method="post">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth_reset_password_' ~ token) }}">
                    <label class="profile-auth__field">
                        <span>{{ 'auth.reset.new_password'|trans }}</span>
                        <span class="profile-auth__input">
                            <i class="fa-solid fa-lock"></i>
                            <input type="password" name="password" autocomplete="new-password" minlength="8" required placeholder="{{ 'auth.register.password_placeholder'|trans }}">
                        </span>
                    </label>
                    <label class="profile-auth__field">
                        <span>{{ 'auth.reset.confirm_password'|trans }}</span>
                        <span class="profile-auth__input">
                            <i class="fa-solid fa-check-double"></i>
                            <input type="password" name="password_confirmation" autocomplete="new-password" minlength="8" required placeholder="{{ 'auth.register.password_placeholder'|trans }}">
                        </span>
                    </label>
                    <button type="submit" class="profile-auth__submit">
                        <span>{{ 'auth.reset.new_submit'|trans }}</span>
                        <i class="fa-solid fa-check"></i>
                    </button>
                </form>
            </article>
        </div>
    </section>
{% endblock %}
