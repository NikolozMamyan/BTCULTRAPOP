{% extends 'front/base.html.twig' %}

{% block title %}{{ 'auth.reset.request_title'|trans }} | ULTRAPOP{% endblock %}
{% block meta_description %}{{ 'auth.reset.request_meta_description'|trans }}{% endblock %}
{% block storefront_data %}data-page="auth-reset"{% endblock %}

{% block main %}
    <section class="auth-reset-page">
        <div class="auth-reset-shell max-w-5xl mx-auto px-5">
            <article class="auth-reset-card">
                <a class="auth-reset-card__back" href="{{ path('app_front_profil') }}">
                    <i class="fa-solid fa-arrow-left"></i>
                    {{ 'auth.reset.back_to_login'|trans }}
                </a>

                <div class="auth-reset-card__icon">
                    <i class="fa-solid fa-key"></i>
                </div>

                <p class="auth-reset-card__eyebrow">{{ 'auth.reset.request_eyebrow'|trans }}</p>
                <h1>{{ 'auth.reset.request_title'|trans }}</h1>
                <p>{{ 'auth.reset.request_text'|trans }}</p>

                {% for type, messages in app.flashes %}
                    {% for message in messages %}
                        <div class="profile-flash profile-flash--{{ type }}">
                            <i class="fa-solid {{ type == 'success' ? 'fa-circle-check' : 'fa-triangle-exclamation' }}"></i>
                            <span>{{ message|trans }}</span>
                        </div>
                    {% endfor %}
                {% endfor %}

                <form class="auth-reset-form" action="{{ path('app_auth_forgot_password_submit') }}" method="post">
                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('auth_forgot_password') }}">
                    <label class="profile-auth__field">
                        <span>{{ 'common.email'|trans }}</span>
                        <span class="profile-auth__input">
                            <i class="fa-regular fa-envelope"></i>
                            <input type="email" name="email" autocomplete="email" required placeholder="ton@email.com">
                        </span>
                    </label>
                    <button type="submit" class="profile-auth__submit">
                        <span>{{ 'auth.reset.request_submit'|trans }}</span>
                        <i class="fa-solid fa-paper-plane"></i>
                    </button>
                </form>
            </article>
        </div>
    </section>
{% endblock %}
