{% set product_image_deferred = defer_image|default(false) %}
{% set show_quantity_selector = quantity_selector|default(false) and product.in_stock %}
{% set max_quantity = product.quantity > 99 ? 99 : product.quantity %}

<article
    class="shop-product-card {{ show_quantity_selector ? 'shop-product-card--quantity' : '' }}"
    data-shop-filters-target="card"
    data-category="{{ product.cat }}"
    data-category-path="{{ product.category_path|default([])|join('|') }}"
    data-license="{{ product.license }}"
    data-price="{{ product.price }}"
    data-popularity="{{ product.pop }}"
    data-rating="{{ product.rating|default(0) ?: 0 }}"
    data-tag="{{ product.tag|default('') }}"
    data-product-url="{{ path('app_front_product', {id: product.id, slug: product.slug}) }}"
    tabindex="0"
>
    <div class="shop-product-card__visual">
        {% if product.tag %}
            {% set tag_class = product.tag == 'Promo' ? 'is-promo' : (product.tag == 'Nouveau' ? 'is-new' : 'is-bestseller') %}
            {% set tag_label = product.tag == 'Promo' ? 'product.tag.promo' : (product.tag == 'Nouveau' ? 'product.tag.new' : 'product.tag.bestseller') %}
            <span class="shop-product-card__tag {{ tag_class }}">
                {{ tag_label|trans }}
            </span>
        {% endif %}

        <div class="shop-product-card__actions">
            <button
                type="button"
                class="favorite-button {{ product.favorite|default(false) ? 'is-active' : '' }}"
                data-action="favorites#toggle"
                data-favorites-product-id-param="{{ product.id }}"
                data-favorite-active-label="{{ 'product.remove_favorite'|trans }}"
                data-favorite-inactive-label="{{ 'product.add_favorite'|trans }}"
                aria-pressed="{{ product.favorite|default(false) ? 'true' : 'false' }}"
                aria-label="{{ (product.favorite|default(false) ? 'product.remove_favorite' : 'product.add_favorite')|trans }}"
            >
                <i class="{{ product.favorite|default(false) ? 'fa-solid' : 'fa-regular' }} fa-heart"></i>
            </button>
            <button
                type="button"
                data-action="product-preview-open"
                data-product-preview-image="{{ product.img }}"
                data-product-preview-title="{{ product.name }}"
                data-product-preview-url="{{ path('app_front_product', {id: product.id, slug: product.slug}) }}"
                aria-label="{{ 'product.preview'|trans({'%name%': product.name}) }}"
            >
                <i class="fa-solid fa-magnifying-glass-plus"></i>
            </button>
        </div>

        <a href="{{ path('app_front_product', {id: product.id, slug: product.slug}) }}" class="shop-product-card__image-link">
            <img
                src="{{ product_image_deferred ? 'data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=' : product.img }}"
                {% if product_image_deferred %}data-src="{{ product.img }}"{% endif %}
                class="{{ product_image_deferred ? 'is-deferred' : '' }}"
                alt="{{ product.name }}"
                loading="lazy"
            >
        </a>
    </div>

    <div class="shop-product-card__body">
        <span class="shop-product-card__category">{{ product.cat }}</span>
        <h2><a href="{{ path('app_front_product', {id: product.id, slug: product.slug}) }}">{{ product.name }}</a></h2>

        <div class="shop-product-card__stock {{ product.in_stock ? 'is-in-stock' : 'is-out-of-stock' }}">
            <i class="fa-solid {{ product.in_stock ? 'fa-circle-check' : 'fa-circle-xmark' }}"></i>
            <small>{{ product.in_stock ? 'product.in_stock'|trans : 'product.out_of_stock'|trans }}</small>
        </div>

        <div class="shop-product-card__price">
            <strong>{{ product.price|number_format(2, ',', ' ') }} €</strong>
            {% if product.old %}
                <del>{{ product.old|number_format(2, ',', ' ') }} €</del>
            {% endif %}
        </div>
    </div>

    {% if show_quantity_selector %}
        <div class="shop-product-card__purchase" data-product-purchase>
            <div class="shop-product-card__quantity" aria-label="{{ 'product.quantity'|trans }}">
                <button
                    type="button"
                    data-action="cart#decrementProductQuantity"
                    aria-label="{{ 'product.quantity_less'|trans }}"
                >
                    <i class="fa-solid fa-minus"></i>
                </button>
                <input
                    type="number"
                    value="1"
                    min="1"
                    max="{{ max_quantity }}"
                    inputmode="numeric"
                    data-product-quantity
                    data-action="change->cart#normalizeProductQuantity blur->cart#normalizeProductQuantity"
                    aria-label="{{ 'product.quantity'|trans }}"
                >
                <button
                    type="button"
                    data-action="cart#incrementProductQuantity"
                    aria-label="{{ 'product.quantity_more'|trans }}"
                >
                    <i class="fa-solid fa-plus"></i>
                </button>
            </div>
            <button
                type="button"
                class="shop-product-card__add cart-add-button"
                data-action="cart#add"
                data-cart-product-id-param="{{ product.id }}"
            >
                <i class="fa-solid fa-bag-shopping"></i>
                {{ 'product.add'|trans }}
            </button>
        </div>
    {% else %}
        <button
            type="button"
            class="shop-product-card__add cart-add-button"
            data-action="cart#add"
            data-cart-product-id-param="{{ product.id }}"
            data-cart-quantity-param="1"
            {{ product.in_stock ? '' : 'disabled' }}
        >
            <i class="fa-solid fa-bag-shopping"></i>
            {{ 'product.add'|trans }}
        </button>
    {% endif %}
</article>
