{% set catalog_products = products|default([]) %}
{% set catalog_categories = categories|default([]) %}
{% set catalog_filter_items = filter_items|default(catalog_categories) %}
{% set catalog_filter_label = filter_label|default('shop.filters.categories') %}
{% set catalog_filter_icon = filter_icon|default('fa-solid fa-layer-group') %}
{% set catalog_filter_field = filter_field|default('category') %}
{% set catalog_max_price = max_price|default(120) %}
{% set catalog_breadcrumb = breadcrumb|default('shop.breadcrumb') %}
{% set catalog_title = title|default('shop.title') %}

{% if catalog_products %}
    <section class="shop-catalog">
        <h1 class="sr-only">{{ catalog_title|trans }}</h1>
        <div
            class="shop-layout max-w-7xl mx-auto px-5"
            data-controller="shop-filters"
            data-shop-filters-all-value="{{ 'shop.filters.all'|trans }}"
            data-shop-filters-filter-field-value="{{ catalog_filter_field }}"
        >
            <button
                type="button"
                class="shop-filter-backdrop"
                data-shop-filters-target="backdrop"
                data-action="shop-filters#closeModal"
                aria-label="{{ 'shop.filters.close'|trans }}"
                tabindex="-1"
            ></button>

            <aside
                id="shop-filters-modal"
                class="shop-sidebar"
                data-shop-filters-target="modal"
                aria-label="{{ 'shop.filters.title'|trans }}"
                tabindex="-1"
            >
                <div class="shop-filter-modal__handle" aria-hidden="true"></div>
                <div class="shop-filter-modal__header">
                    <div>
                        <span>{{ 'shop.filters.mobile_eyebrow'|trans }}</span>
                        <h2>{{ 'shop.filters.title'|trans }}</h2>
                    </div>
                    <div class="shop-filter-modal__header-actions">
                        <button type="button" class="shop-filter-reset" data-action="shop-filters#reset">
                            {{ 'shop.filters.reset'|trans }}
                        </button>
                        <button
                            type="button"
                            class="shop-filter-close"
                            data-action="shop-filters#closeModal"
                            aria-label="{{ 'shop.filters.close'|trans }}"
                        >
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                </div>

                <section class="shop-filter-card shop-filter-card--categories">
                    <h2 class="shop-filter-title">
                        <span class="shop-filter-title-icon-wrapper">
                            <i class="{{ catalog_filter_field == 'category' ? 'fa-solid fa-compass' : catalog_filter_icon }}"></i>
                        </span>
                        {{ catalog_filter_label|trans }}
                    </h2>

                    {% set first_filter_group = catalog_filter_items|first %}
                    {% set root_thumbnail = catalog_filter_field == 'category'
                        ? 'https://ultrapop.com/img/cms/Germany.png'
                        : first_filter_group.image|default(catalog_products|first.img|default('')) %}
                    {% set root_thumbnail_fallback = first_filter_group.fallbackImage|default(catalog_products|first.img|default('')) %}

                    <div class="shop-category-list">
                        <button
                            type="button"
                            class="shop-category-button shop-category-button--root is-active"
                            data-shop-filters-target="category"
                            data-shop-filters-category-param="all"
                            data-action="shop-filters#selectCategory"
                        >
                            <span class="shop-category-button__label">
                                {% if catalog_filter_field == 'category' %}
                                    <span class="shop-category-img-container shop-category-img-container--root">
                                        <img
                                            src="{{ root_thumbnail }}"
                                            data-fallback-src="{{ root_thumbnail_fallback }}"
                                            data-action="error->shop-filters#useImageFallback"
                                            alt=""
                                            width="44"
                                            height="44"
                                            loading="lazy"
                                        >
                                    </span>
                                {% else %}
                                    <span class="shop-category-button__icon">
                                        <i class="fa-solid fa-border-all"></i>
                                    </span>
                                {% endif %}
                                <strong>{{ 'shop.filters.all'|trans }}</strong>
                            </span>
                            <span class="shop-category-button__count">{{ catalog_products|length }}</span>
                        </button>
                        {% if catalog_filter_field == 'category' %}
                            {% for filter_group in catalog_filter_items %}
                                {% set group_subtitle = filter_group.name == 'Boissons'
                                    ? 'shop.filters.group.drinks'
                                    : (filter_group.name == 'Épicerie salée'
                                        ? 'shop.filters.group.savory'
                                        : (filter_group.name == 'Épicerie sucrée'
                                            ? 'shop.filters.group.sweet'
                                            : 'shop.filters.group.boxes')) %}
                                <details
                                    class="shop-category-group"
                                    data-shop-filters-target="categoryGroup"
                                    data-action="toggle->shop-filters#toggleCategoryGroup"
                                    {{ loop.first ? 'open' : '' }}
                                >
                                    <summary>
                                        <span class="shop-category-img-container">
                                            <img
                                                src="{{ filter_group.image ?: root_thumbnail }}"
                                                data-fallback-src="{{ filter_group.fallbackImage ?: root_thumbnail_fallback }}"
                                                data-action="error->shop-filters#useImageFallback"
                                                alt=""
                                                width="44"
                                                height="44"
                                                loading="lazy"
                                            >
                                        </span>
                                        <span class="shop-category-group__title">
                                            <strong>{{ filter_group.name }}</strong>
                                            <small>{{ group_subtitle|trans }}</small>
                                        </span>
                                        <span class="shop-category-group__count">{{ filter_group.count }}</span>
                                        <i class="shop-category-group__chevron fa-solid fa-chevron-down"></i>
                                    </summary>
                                    <div class="shop-category-group__panel">
                                        <button
                                            type="button"
                                            class="shop-category-button shop-category-button--parent"
                                            data-shop-filters-target="category"
                                            data-shop-filters-category-param="{{ filter_group.name }}"
                                            data-action="shop-filters#selectCategory"
                                        >
                                            <span class="shop-category-button__label">
                                                <i class="fa-solid fa-circle-notch"></i>
                                                <strong>{{ 'shop.filters.view_group_short'|trans }}</strong>
                                            </span>
                                            <span class="shop-category-button__count">{{ filter_group.count }}</span>
                                        </button>
                                        {% for filter_item in filter_group.children %}
                                            <button
                                                type="button"
                                                class="shop-category-button shop-category-button--child"
                                                data-shop-filters-target="category"
                                                data-shop-filters-category-param="{{ filter_item.name }}"
                                                data-action="shop-filters#selectCategory"
                                                title="{{ filter_item.name }}"
                                            >
                                                <span class="shop-category-button__label">
                                                    <i class="fa-solid fa-angle-right"></i>
                                                    <span>{{ filter_item.name }}</span>
                                                </span>
                                                <span class="shop-category-button__count">{{ filter_item.count }}</span>
                                            </button>
                                        {% endfor %}
                                    </div>
                                </details>
                            {% endfor %}
                        {% else %}
                            {% for filter_item in catalog_filter_items %}
                                <button
                                    type="button"
                                    class="shop-category-button"
                                    data-shop-filters-target="category"
                                    data-shop-filters-category-param="{{ filter_item }}"
                                    data-action="shop-filters#selectCategory"
                                >
                                    <span>{{ filter_item }}</span>
                                </button>
                            {% endfor %}
                        {% endif %}
                    </div>
                </section>

                <section class="shop-filter-card">
                    <h2 class="shop-filter-title">
                        <i class="fa-solid fa-sliders"></i>
                        {{ 'shop.filters.max_price'|trans }}
                    </h2>
                    <input
                        class="shop-price-range"
                        type="range"
                        min="0"
                        max="{{ catalog_max_price }}"
                        value="{{ catalog_max_price }}"
                        step="1"
                        data-shop-filters-target="price"
                        data-action="input->shop-filters#filter"
                        aria-label="{{ 'shop.filters.max_price'|trans }}"
                    >
                    <p class="shop-price-label">
                        {{ 'shop.filters.up_to'|trans }}
                        <strong><span data-shop-filters-target="priceLabel">{{ catalog_max_price }}</span> €</strong>
                    </p>
                </section>

                <section class="shop-filter-card" style="display:none;">
                    <h2 class="shop-filter-title">
                        <i class="fa-solid fa-tag"></i>
                        {{ 'shop.filters.quick'|trans }}
                    </h2>
                    <label class="shop-filter-check">
                        <input
                            type="checkbox"
                            data-shop-filters-target="promo"
                            data-action="change->shop-filters#filter"
                        >
                        <span>{{ 'shop.filters.promo_only'|trans }}</span>
                    </label>
                    <label class="shop-filter-check">
                        <input
                            type="checkbox"
                            data-shop-filters-target="new"
                            data-action="change->shop-filters#filter"
                        >
                        <span>{{ 'shop.filters.new_only'|trans }}</span>
                    </label>
                </section>

                <div class="shop-filter-modal__footer">
                    <button type="button" data-action="shop-filters#closeModal">
                        {{ 'shop.filters.show_results'|trans }}
                        <span data-shop-filters-target="mobileCount">{{ catalog_products|length }}</span>
                    </button>
                </div>
            </aside>

            <div class="shop-results">
                <div class="shop-results-toolbar">
                    <div class="shop-results-summary">
                        <p>
                            <strong data-shop-filters-target="count">{{ catalog_products|length }}</strong>
                            {{ 'shop.products'|trans }}
                        </p>
                        <button
                            type="button"
                            class="shop-filter-trigger"
                            data-shop-filters-target="trigger"
                            data-action="shop-filters#openModal"
                            aria-controls="shop-filters-modal"
                            aria-expanded="false"
                        >
                            <i class="fa-solid fa-sliders"></i>
                            {{ 'shop.filters.open'|trans }}
                            <span data-shop-filters-target="activeCount" hidden>0</span>
                        </button>
                    </div>
                    <label class="shop-sort">
                        <span class="sr-only">{{ 'shop.sort.label'|trans }}</span>
                        <select data-shop-filters-target="sort" data-action="change->shop-filters#filter">
                            <option value="pop">{{ 'shop.sort.popularity'|trans }}</option>
                            <option value="price-asc">{{ 'shop.sort.price_asc'|trans }}</option>
                            <option value="price-desc">{{ 'shop.sort.price_desc'|trans }}</option>
                        </select>
                        <i class="fa-solid fa-chevron-down" aria-hidden="true"></i>
                    </label>
                </div>

                <div class="shop-products-grid" data-shop-filters-target="grid">
                    {% for product in catalog_products %}
                        {% include 'front/boutique/_product_card.html.twig' with {product: product} only %}
                    {% endfor %}
                </div>

                <div class="shop-no-results" data-shop-filters-target="empty" hidden>
                    <i class="fa-solid fa-box-open"></i>
                    <p>{{ 'shop.filters.no_results'|trans }}</p>
                </div>
            </div>
        </div>
    </section>
{% else %}
    <section class="bg-bg-light border-b border-border-c">
        <div class="max-w-7xl mx-auto px-5 py-8">
            <p class="text-xs text-text-light font-semibold mb-2">
                <a href="{{ path('app_front_home') }}" class="hover:text-primary">{{ 'common.home'|trans }}</a>
                <i class="fa-solid fa-chevron-right text-[8px] mx-2"></i> {{ catalog_breadcrumb|trans }}
            </p>
            <h1 class="font-display text-3xl md:text-4xl font-extrabold">{{ catalog_title|trans }}</h1>
        </div>
    </section>
    <section class="max-w-7xl mx-auto px-5 py-10 md:py-16">
        {% include 'front/components/_catalog_empty.html.twig' with {
            icon: icon,
            eyebrow: eyebrow,
            title: empty_title,
            text: empty_text,
            action_url: path('app_front_home'),
            action_label: 'catalog.back_home'
        } only %}
    </section>
{% endif %}
