{% extends 'front/base.html.twig' %}

{% block title %}{{ product.seo_title ?: product.name }} | ULTRAPOP{% endblock %}
{% block meta_description %}{{ product.seo_description ?: product.description ?: 'product.description'|trans({'%name%': product.name}) }}{% endblock %}
{% block canonical_url %}{{ seo_origin ~ path('app_front_product', {id: product.id, slug: product.slug}) }}{% endblock %}
{% block og_type %}product{% endblock %}
{% block og_image %}{{ product.img starts with 'http://' or product.img starts with 'https://' ? product.img : seo_origin ~ product.img }}{% endblock %}
{% block structured_data %}
    {% set product_schema = {
        '@context': 'https://schema.org',
        '@type': 'Product',
        name: product.name,
        description: product.seo_description ?: product.description,
        image: [product.img starts with 'http://' or product.img starts with 'https://' ? product.img : seo_origin ~ product.img],
        sku: product.reference,
        category: product.cat,
        brand: {
            '@type': 'Brand',
            name: 'ULTRAPOP'
        },
        offers: {
            '@type': 'Offer',
            url: seo_origin ~ path('app_front_product', {id: product.id, slug: product.slug}),
            priceCurrency: 'EUR',
            price: product.price|number_format(2, '.', ''),
            availability: product.in_stock ? 'https://schema.org/InStock' : 'https://schema.org/OutOfStock',
            itemCondition: 'https://schema.org/NewCondition',
            seller: {
                '@type': 'Organization',
                name: 'ULTRAPOP'
            }
        }
    } %}
    {% if product.ean %}
        {% set product_schema = product_schema|merge({gtin13: product.ean}) %}
    {% endif %}
    {% set breadcrumb_schema = {
        '@context': 'https://schema.org',
        '@type': 'BreadcrumbList',
        itemListElement: [
            {
                '@type': 'ListItem',
                position: 1,
                name: 'common.home'|trans,
                item: seo_origin ~ path('app_front_home')
            },
            {
                '@type': 'ListItem',
                position: 2,
                name: 'common.shop'|trans,
                item: seo_origin ~ path('app_front_boutique')
            },
            {
                '@type': 'ListItem',
                position: 3,
                name: product.name,
                item: seo_origin ~ path('app_front_product', {id: product.id, slug: product.slug})
            }
        ]
    } %}
    <script type="application/ld+json">{{ product_schema|json_encode|raw }}</script>
    <script type="application/ld+json">{{ breadcrumb_schema|json_encode|raw }}</script>
{% endblock %}
{% block storefront_data %}data-page="product"{% endblock %}

{% block main %}
    <header class="product-hero" style="--product-hero-image: url('{{ product.img }}')">
        <div class="product-hero__overlay"></div>
        <div class="product-hero__content max-w-7xl mx-auto px-5">
            <p>
                <a href="{{ path('app_front_home') }}">{{ 'common.home'|trans }}</a>
                <i class="fa-solid fa-chevron-right"></i>
                <a href="{{ path('app_front_boutique') }}">{{ 'common.shop'|trans }}</a>
                <i class="fa-solid fa-chevron-right"></i>
                {{ product.name }}
            </p>
            <span>{{ product.cat }}</span>
            <h1>{{ product.name }}</h1>
        </div>
    </header>

    <main
        class="product-page max-w-7xl mx-auto px-5"
        data-controller="product-detail"
        data-product-detail-product-id-value="{{ product.id }}"
    >
        <article class="product-detail">
            <div class="product-detail__gallery">
                <div class="product-detail__visual">
                    {% if product.tag %}
                        {% set tag_class = product.tag == 'Promo' ? 'is-promo' : (product.tag == 'Nouveau' ? 'is-new' : 'is-bestseller') %}
                        {% set tag_label = product.tag == 'Promo' ? 'product.tag.promo' : (product.tag == 'Nouveau' ? 'product.tag.new' : 'product.tag.bestseller') %}
                        <span class="shop-product-card__tag {{ tag_class }}">
                            {{ tag_label|trans }}
                        </span>
                    {% endif %}
                    <img src="{{ product.img }}" alt="{{ product.name }}">
                </div>
                <button type="button" class="product-detail__thumbnail is-active" aria-label="{{ 'product.main_image'|trans }}">
                    <img src="{{ product.img }}" alt="">
                </button>
            </div>

            <div class="product-detail__content">
                <div class="product-detail__badges">
                    <span>{{ product.cat }}</span>
                    <span class="{{ product.in_stock ? 'is-stock' : 'is-out-of-stock' }}">
                        <i class="fa-solid {{ product.in_stock ? 'fa-circle-check' : 'fa-circle-xmark' }}"></i>
                        {{ product.in_stock ? 'product.in_stock'|trans : 'product.out_of_stock'|trans }}
                    </span>
                </div>

                <h2>{{ product.name }}</h2>

                <div class="product-detail__meta">
                    <span><i class="fa-solid fa-clapperboard"></i> {{ product.license }}</span>
                    <span><i class="fa-solid fa-barcode"></i> {{ product.reference }}</span>
                </div>

                <div class="product-detail__price">
                    <strong>{{ product.price|number_format(2, ',', ' ') }} €</strong>
                    {% if product.old %}
                        <del>{{ product.old|number_format(2, ',', ' ') }} €</del>
                        <span>-{{ (((product.old - product.price) / product.old) * 100)|round }}%</span>
                    {% endif %}
                </div>

                <div class="product-detail__stock {{ product.in_stock ? 'is-in-stock' : 'is-out-of-stock' }}">
                    <i class="fa-solid {{ product.in_stock ? 'fa-bolt' : 'fa-circle-xmark' }}"></i>
                    <div>
                        <strong>{{ product.in_stock ? 'product.available_now'|trans : 'product.unavailable_now'|trans }}</strong>
                        <span>{{ product.in_stock ? 'product.shipping_note'|trans : 'product.unavailable_note'|trans }}</span>
                    </div>
                </div>

                <p class="product-detail__description">{{ product.description ?: 'product.description'|trans({'%name%': product.name}) }}</p>

                <div class="product-detail__purchase">
                    <div class="product-quantity" aria-label="{{ 'product.quantity'|trans }}">
                        <button type="button" data-action="product-detail#decrement" aria-label="{{ 'product.quantity_less'|trans }}">
                            <i class="fa-solid fa-minus"></i>
                        </button>
                        <span data-product-detail-target="quantity">1</span>
                        <button type="button" data-action="product-detail#increment" aria-label="{{ 'product.quantity_more'|trans }}">
                            <i class="fa-solid fa-plus"></i>
                        </button>
                    </div>
                    <button type="button" class="product-detail__primary cart-add-button" data-action="product-detail#addToCart" {{ product.in_stock ? '' : 'disabled' }}>
                        <i class="fa-solid fa-bag-shopping"></i>
                        {{ 'product.add_to_cart'|trans }}
                    </button>
                    <button
                        type="button"
                        class="product-detail__secondary favorite-button {{ product.favorite|default(false) ? 'is-active' : '' }}"
                        data-action="favorites#toggle"
                        data-favorites-product-id-param="{{ product.id }}"
                        data-favorite-active-label="{{ 'product.remove_favorite'|trans }}"
                        data-favorite-inactive-label="{{ 'product.add_favorite'|trans }}"
                        aria-pressed="{{ product.favorite|default(false) ? 'true' : 'false' }}"
                        aria-label="{{ (product.favorite|default(false) ? 'product.remove_favorite' : 'product.add_favorite')|trans }}"
                    >
                        <i class="{{ product.favorite|default(false) ? 'fa-solid' : 'fa-regular' }} fa-heart"></i>
                    </button>
                </div>

                <div class="product-detail__benefits">
                    <span><i class="fa-solid fa-truck-fast"></i> {{ 'product.fast_delivery'|trans }}</span>
                    <span><i class="fa-solid fa-lock"></i> {{ 'product.secure_payment'|trans }}</span>
                    <span><i class="fa-solid fa-clapperboard"></i> {{ 'product.official_license'|trans }}</span>
                </div>
            </div>
        </article>

        <section class="product-tabs">
            <div class="product-tabs__nav-wrapper" role="tablist">
                <div class="product-tabs__nav">
                    <button type="button" class="is-active" data-product-detail-target="tab" data-product-detail-panel-param="description" data-action="product-detail#selectTab">
                        {{ 'product.tabs.description'|trans }}
                    </button>
                    {% if product.ingredients %}
                        <button type="button" data-product-detail-target="tab" data-product-detail-panel-param="ingredients" data-action="product-detail#selectTab">
                            {{ 'product.tabs.ingredients'|trans }}
                        </button>
                    {% endif %}
                    <button type="button" data-product-detail-target="tab" data-product-detail-panel-param="reviews" data-action="product-detail#selectTab">
                        {{ 'product.tabs.reviews'|trans }}
                        {% if reviews.count > 0 %}<span>{{ reviews.count }}</span>{% endif %}
                    </button>
                </div>
            </div>

            <div class="product-tabs__panel is-active" data-product-detail-target="panel" data-panel="description">
                <div class="product-tab-copy">
                    <span class="product-tab-copy__icon"><i class="fa-solid fa-book-open"></i></span>
                    <div>
                        <span class="product-tab-copy__eyebrow">{{ product.license }}</span>
                        <h3>{{ 'product.description_heading'|trans }}</h3>
                        <p>{{ product.description ?: 'product.long_description'|trans({'%name%': product.name, '%category%': product.cat}) }}</p>
                    </div>
                </div>
            </div>
            {% if product.ingredients %}
                <div class="product-tabs__panel" data-product-detail-target="panel" data-panel="ingredients" hidden>
                    <div class="product-ingredients-heading">
                        <span class="product-tab-copy__icon is-green"><i class="fa-solid fa-leaf"></i></span>
                        <div>
                            <h3>{{ 'product.ingredients_heading'|trans }}</h3>
                            <p>{{ 'product.ingredients_intro'|trans }}</p>
                        </div>
                    </div>
                    <div class="product-ingredient-tags">
                        {% set ingredient_tags = product.ingredients|replace({"\r\n": ' ', "\n": ' ', ';': ','})|split(',') %}
                        {% for ingredient in ingredient_tags %}
                            {% if ingredient|trim %}
                                <span class="product-ingredient-tag">
                                    <i class="fa-solid fa-check"></i>
                                    {{ ingredient|trim }}
                                </span>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
            <div class="product-tabs__panel" data-product-detail-target="panel" data-panel="reviews" hidden>
                {% if reviews.count > 0 %}
                    <div class="product-reviews__overview">
                        <div class="product-reviews__score">
                            <strong>{{ reviews.average|number_format(1, ',', '') }}</strong>
                            <div class="product-review-stars" aria-label="{{ 'product.reviews.rating_label'|trans({'%rating%': reviews.average}) }}">
                                {% for star in 1..5 %}
                                    <i class="{{ reviews.average >= star ? 'fa-solid fa-star' : (reviews.average >= star - 0.5 ? 'fa-solid fa-star-half-stroke' : 'fa-regular fa-star') }}"></i>
                                {% endfor %}
                            </div>
                            <span>{{ 'product.reviews.based_on'|trans({'%count%': reviews.count}) }}</span>
                            {# <small class="product-reviews__notice">{{ 'product.reviews.preproduction_notice'|trans }}</small> #}
                        </div>
                        <div class="product-reviews__distribution">
                            {% for rating in 5..1 %}
                                {% set row = reviews.distribution[rating] %}
                                <div class="product-rating-row">
                                    <span>{{ 'product.reviews.stars'|trans({'%count%': rating}) }}</span>
                                    <div class="product-rating-bar">
                                        <span style="width: {{ row.percentage }}%"></span>
                                    </div>
                                    <strong>{{ row.percentage }}%</strong>
                                </div>
                            {% endfor %}
                        </div>
                    </div>

                    <div class="product-reviews__list">
                        {% for review in reviews.items %}
                            <article class="product-review-card">
                                <header>
                                    <div class="product-review-card__identity">
                                        <span>{{ review.author|first|upper }}</span>
                                        <div>
                                            <strong>{{ review.author }}</strong>
                                        </div>
                                    </div>
                                    <time datetime="{{ review.created_at|date('Y-m-d') }}">{{ review.created_at|date('d/m/Y') }}</time>
                                </header>
                                <div class="product-review-stars is-small" aria-hidden="true">
                                    {% for star in 1..5 %}
                                        <i class="{{ review.rating >= star ? 'fa-solid' : 'fa-regular' }} fa-star"></i>
                                    {% endfor %}
                                </div>
                                {% if review.title %}<h4>{{ review.title }}</h4>{% endif %}
                                <p>{{ review.content }}</p>
                            </article>
                        {% endfor %}
                    </div>
                {% else %}
                    <div class="product-no-reviews">
                        <i class="fa-regular fa-comment-dots"></i>
                        <p>{{ 'product.no_reviews'|trans }}</p>
                    </div>
                {% endif %}
            </div>
        </section>

        <section class="product-related">
            <div class="product-related__heading">
                <div>
                    <span>{{ 'product.related_eyebrow'|trans }}</span>
                    <h2>{{ 'product.related'|trans }}</h2>
                </div>
                <a href="{{ path('app_front_boutique') }}">{{ 'common.see_all'|trans }} <i class="fa-solid fa-arrow-right"></i></a>
            </div>
            <div class="shop-products-grid">
                {% for related_product in related_products %}
                    {% include 'front/boutique/_product_card.html.twig' with {product: related_product} only %}
                {% endfor %}
            </div>
        </section>
    </main>
{% endblock %}
