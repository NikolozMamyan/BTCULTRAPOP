{% set current_route = app.request.attributes.get('_route') %}

<header class="sticky top-0 z-40 bg-white/85 backdrop-blur-xl border-b border-border-c">
    <div class="max-w-7xl mx-auto px-5 h-[72px] flex items-center justify-between gap-6">
        <a href="{{ path('app_front_home') }}" class="flex items-center shrink-0">
            <img src="{{ asset('img/logo/logotype.svg') }}" alt="ULTRAPOP" class="h-9 w-auto" data-logo-fallback>
        </a>

        <nav class="hidden lg:flex items-center gap-8 font-semibold text-sm text-text-dark" aria-label="{{ 'nav.primary_label'|trans }}">
            <a href="{{ path('app_front_home') }}" class="nav-link {{ current_route == 'app_front_home' ? 'active' : '' }}">{{ 'common.home'|trans }}</a>
            <a href="{{ path('app_front_boutique') }}" class="nav-link {{ current_route in ['app_front_boutique'] ? 'active' : '' }}">{{ 'common.shop'|trans }}</a>
            {# <a href="{{ path('app_front_boutique', {filter: 'nouveautes'}) }}" class="nav-link">{{ 'common.new_products'|trans }}</a> #}
            <a href="{{ path('app_front_licences') }}" class="nav-link {{ current_route == 'app_front_licences' ? 'active' : '' }}">{{ 'common.licenses'|trans }}</a>
            {# <a href="{{ path('app_front_soldes') }}" class="nav-link text-primary {{ current_route == 'app_front_soldes' ? 'active' : '' }}">{{ 'common.sales'|trans }}</a> #}
        </nav>

        <div class="flex items-center gap-2 sm:gap-3">
            <button type="button" data-action="search-open" class="md:hidden w-10 h-10 rounded-full hover:bg-bg-light flex items-center justify-center text-text-dark" aria-label="{{ 'nav.search'|trans }}">
                <i class="fa-solid fa-magnifying-glass"></i>
            </button>
            <button type="button" data-action="search-open" class="hidden md:flex items-center bg-bg-light border border-border-c rounded-full px-4 h-10 w-56 hover:border-primary transition-colors text-text-light text-sm">
                <i class="fa-solid fa-magnifying-glass mr-2"></i>
                <span>{{ 'nav.search_placeholder'|trans }}</span>
                <kbd class="ml-auto text-[10px] bg-white border border-border-c rounded px-1.5 py-0.5">⌘K</kbd>
            </button>
            <a href="{{ path('app_front_favoris') }}" class="hidden lg:flex w-10 h-10 rounded-full hover:bg-bg-light items-center justify-center text-text-dark transition-colors relative" aria-label="{{ 'nav.favorites_label'|trans }}">
                <i class="fa-regular fa-heart"></i>
            </a>
            <a href="{{ path('app_front_profil') }}" class="header-profile-link flex w-10 h-10 rounded-full hover:bg-bg-light items-center justify-center text-text-dark transition-colors {{ current_route == 'app_front_profil' ? 'bg-bg-light text-primary' : '' }}" aria-label="{{ 'nav.profile_label'|trans }}">
                {% if app.user and app.user.avatarPath %}
                    <img class="header-profile-link__avatar" src="{{ asset(app.user.avatarPath) }}" alt="">
                {% else %}
                    <i class="fa-regular fa-user"></i>
                {% endif %}
            </a>
            <button type="button" data-action="cart-open" class="hidden lg:flex w-10 h-10 rounded-full bg-primary hover:bg-primary-d text-white items-center justify-center transition-colors relative shadow-md-c" aria-label="{{ 'nav.open_cart'|trans }}">
                <i class="fa-solid fa-bag-shopping"></i>
                <span class="cart-count absolute -top-1 -right-1 w-5 h-5 bg-secondary text-text-dark text-[11px] font-bold rounded-full flex items-center justify-center">0</span>
            </button>
        </div>
    </div>
</header>
