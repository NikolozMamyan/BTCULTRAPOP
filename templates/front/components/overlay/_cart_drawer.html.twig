<button type="button" id="cart-overlay" data-action="cart-close" class="fixed inset-0 bg-black/40 backdrop-blur-sm z-[60] hidden" aria-label="{{ 'overlay.close_cart'|trans }}"></button>
<aside id="cart-drawer" class="cart-drawer fixed top-0 right-0 h-full w-full max-w-md bg-white z-[70] shadow-2xl flex flex-col" aria-label="{{ 'overlay.cart_title'|trans }}">
    <div class="flex items-center justify-between px-6 py-5 border-b border-border-c">
        <h3 class="font-display text-xl font-extrabold flex items-center gap-2"><i class="fa-solid fa-bag-shopping text-primary"></i> {{ 'overlay.cart_title'|trans }}</h3>
        <button type="button" data-action="cart-close" class="w-9 h-9 rounded-full hover:bg-bg-light flex items-center justify-center" aria-label="{{ 'common.close'|trans }}"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <div class="px-6 py-3 bg-bg-light border-b border-border-c">
        <p id="ship-msg" class="text-xs font-semibold mb-2"></p>
        <div class="h-2 bg-border-c rounded-full overflow-hidden"><div id="ship-bar" class="ship-bar h-full bg-success rounded-full" style="width:0%"></div></div>
    </div>
    <div id="cart-items" class="flex-1 overflow-y-auto px-6 py-4 space-y-4"></div>
    <div class="border-t border-border-c px-6 py-5 space-y-4">
        <div class="flex justify-between text-sm"><span class="text-text-light">{{ 'overlay.subtotal'|trans }}</span><span id="cart-subtotal" class="font-bold">0,00€</span></div>
        <div class="flex justify-between text-sm"><span class="text-text-light">{{ 'overlay.delivery'|trans }}</span><span class="font-bold text-success">{{ 'overlay.free'|trans }}</span></div>
        <div class="flex justify-between text-lg font-extrabold border-t border-border-c pt-3"><span>{{ 'overlay.total'|trans }}</span><span id="cart-total" class="text-primary">0,00€</span></div>
        <a href="{{ path('app_front_boutique') }}" class="w-full bg-text-dark hover:bg-primary text-white font-bold py-4 rounded-full transition-colors flex items-center justify-center">{{ 'overlay.discover_shop'|trans }} <i class="fa-solid fa-arrow-right ml-2"></i></a>
    </div>
</aside>
