<div
    id="search-modal"
    class="modal-wrap search-modal fixed inset-0 z-[90] hidden"
    data-controller="search"
    data-search-url-value="{{ path('app_api_search_products') }}"
    data-search-initial-title-value="{{ 'overlay.search_initial_title'|trans }}"
    data-search-initial-text-value="{{ 'overlay.search_initial_text'|trans }}"
    data-search-no-results-title-value="{{ 'overlay.search_no_results_title'|trans }}"
    data-search-no-results-text-value="{{ 'overlay.search_no_results_text'|trans }}"
    data-search-error-title-value="{{ 'overlay.search_error_title'|trans }}"
    data-search-error-text-value="{{ 'overlay.search_error_text'|trans }}"
    data-search-in-stock-value="{{ 'product.in_stock'|trans }}"
    data-search-out-of-stock-value="{{ 'product.out_of_stock'|trans }}"
    data-search-result-count-value="{{ 'overlay.search_result_count'|trans }}"
    data-search-loading-value="{{ 'common.loading'|trans }}"
>
    <button type="button" data-action="search-close" class="absolute inset-0 bg-black/50 backdrop-blur-sm" aria-label="{{ 'overlay.close_search'|trans }}"></button>
    <section class="modal-box search-modal__box relative max-w-2xl mx-auto mt-20 bg-white rounded-lg-c shadow-lg-c overflow-hidden mx-4" role="dialog" aria-modal="true" aria-labelledby="search-modal-title">
        <div class="search-modal__header">
            <span class="search-modal__title-icon"><i class="fa-solid fa-magnifying-glass"></i></span>
            <div>
                <strong id="search-modal-title">{{ 'overlay.search_title'|trans }}</strong>
                <small>{{ 'overlay.search_subtitle'|trans }}</small>
            </div>
            <button type="button" data-action="search-close" class="search-modal__close" aria-label="{{ 'common.close'|trans }}"><i class="fa-solid fa-xmark"></i></button>
        </div>

        <div class="search-modal__input-wrap">
            <i class="fa-solid fa-magnifying-glass"></i>
            <input
                id="search-input"
                type="search"
                placeholder="{{ 'overlay.search_product'|trans }}"
                autocomplete="off"
                data-search-target="input"
                data-action="input->search#search"
            >
            <button type="button" data-search-target="clear" data-action="search#clear" aria-label="{{ 'overlay.search_clear'|trans }}" hidden>
                <i class="fa-solid fa-circle-xmark"></i>
            </button>
            <kbd>Esc</kbd>
        </div>

        <div id="search-results" class="search-modal__results" data-search-target="results" aria-live="polite"></div>
    </section>
</div>
