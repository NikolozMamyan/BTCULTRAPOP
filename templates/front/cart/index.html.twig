{% extends 'front/base.html.twig' %}

{% block title %}{{ 'page.cart.title'|trans }}{% endblock %}
{% block storefront_data %}data-page="cart"{% endblock %}

{% block main %}
    <section class="bg-bg-light border-b border-border-c">
        <div class="max-w-7xl mx-auto px-5 py-8">
            <p class="text-xs text-text-light font-semibold mb-2">
                <a href="{{ path('app_front_home') }}" class="hover:text-primary">{{ 'common.home'|trans }}</a>
                <i class="fa-solid fa-chevron-right text-[8px] mx-2"></i> {{ 'common.cart'|trans }}
            </p>
            <h1 class="font-display text-3xl md:text-4xl font-extrabold">{{ 'cart.title'|trans }}</h1>
        </div>
    </section>

    <section class="cart-page max-w-7xl mx-auto px-5 py-10 md:py-16">
        <div class="cart-page__layout">
            <section class="cart-page__panel" aria-label="{{ 'cart.title'|trans }}">
                <div class="cart-page__panel-head">
                    <div>
                        <span>{{ 'cart.items'|trans }}</span>
                        <strong class="cart-count">{{ cart.totalQuantity }}</strong>
                    </div>
                    <a href="{{ path('app_front_boutique') }}">{{ 'overlay.discover_shop'|trans }}</a>
                </div>

                <div id="cart-page-items" class="cart-page__items">
                    {% if cart.empty %}
                        {% include 'front/components/_catalog_empty.html.twig' with {
                            icon: 'fa-solid fa-bag-shopping',
                            eyebrow: 'cart.empty_eyebrow',
                            title: 'cart.empty_title',
                            text: 'cart.empty_text',
                            action_url: path('app_front_boutique'),
                            action_label: 'overlay.discover_shop'
                        } only %}
                    {% else %}
                        {% for item in cart.items %}
                            <article
                                class="cart-line"
                                data-cart-item-id="{{ item.id }}"
                                data-cart-remove-url="{{ item.removeUrl }}"
                            >
                                <a class="cart-line__media" href="{{ item.productUrl ?: '#' }}">
                                    {% if item.image %}
                                        <img src="{{ item.image }}" alt="">
                                    {% else %}
                                        <i class="fa-solid fa-box"></i>
                                    {% endif %}
                                </a>
                                <div class="cart-line__content">
                                    <div class="cart-line__top">
                                        <a href="{{ item.productUrl ?: '#' }}">{{ item.name }}</a>
                                        <button type="button" class="cart-line__remove" data-action="cart#remove" data-cart-url-param="{{ item.removeUrl }}" aria-label="{{ 'cart.remove_item'|trans }}">
                                            <i class="fa-solid fa-xmark"></i>
                                        </button>
                                    </div>
                                    <span>{{ item.unitPriceFormatted }}</span>
                                    <div class="cart-line__bottom">
                                        <div class="cart-line__quantity">
                                            <button type="button" data-action="cart#decrement" data-cart-url-param="{{ item.updateUrl }}" data-cart-quantity-param="{{ item.quantity }}" aria-label="-">
                                                <i class="fa-solid fa-minus"></i>
                                            </button>
                                            <strong>{{ item.quantity }}</strong>
                                            <button type="button" data-action="cart#increment" data-cart-url-param="{{ item.updateUrl }}" data-cart-quantity-param="{{ item.quantity }}" aria-label="+">
                                                <i class="fa-solid fa-plus"></i>
                                            </button>
                                        </div>
                                        <strong>{{ item.totalFormatted }}</strong>
                                    </div>
                                </div>
                            </article>
                        {% endfor %}
                    {% endif %}
                </div>
            </section>

            <aside class="cart-page__summary" aria-label="{{ 'cart.summary'|trans }}">
                <h2>{{ 'cart.summary'|trans }}</h2>
                {% for message in app.flashes('promo_success') %}
                    <div class="cart-promo-flash cart-promo-flash--success">
                        <i class="fa-solid fa-circle-check"></i>
                        {{ message|trans }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('promo_error') %}
                    <div class="cart-promo-flash cart-promo-flash--error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        {{ message|trans }}
                    </div>
                {% endfor %}
                {% for message in app.flashes('error') %}
                    <div class="cart-promo-flash cart-promo-flash--error">
                        <i class="fa-solid fa-circle-exclamation"></i>
                        {{ message|trans }}
                    </div>
                {% endfor %}
                <div class="cart-page__shipping">
                    {% include 'front/components/cart/_shipping_meter.html.twig' with {
                        prefix: 'page',
                        cart: cart
                    } only %}
                </div>
                <dl>
                    <div>
                        <dt>{{ 'overlay.subtotal'|trans }}</dt>
                        <dd id="cart-page-subtotal">{{ cart.subtotalFormatted }}</dd>
                    </div>
                    <div>
                        <dt>{{ 'overlay.delivery'|trans }}</dt>
                        <dd id="cart-page-shipping" class="{{ cart.shippingFree ? 'is-free' : '' }}">{{ cart.shippingDisplay }}</dd>
                    </div>
                    <div id="cart-page-discount-row" class="cart-promo-discount {{ cart.hasDiscount ? '' : 'hidden' }}">
                        <dt>{{ 'promo.cart.discount'|trans }} <small id="cart-page-promo-code">{{ cart.promoCode }}</small></dt>
                        <dd id="cart-page-discount">{{ cart.discountFormatted }}</dd>
                    </div>
                    <div class="cart-page__summary-total">
                        <dt>{{ 'overlay.total'|trans }}</dt>
                        <dd id="cart-page-total">{{ cart.totalFormatted }}</dd>
                    </div>
                </dl>
                {% if not cart.empty %}
                    <div
                        id="cart-promo"
                        class="cart-promo"
                        data-apply-url="{{ path('app_front_cart_promo_apply') }}"
                        data-remove-url="{{ path('app_front_cart_promo_remove') }}"
                        data-csrf-token="{{ csrf_token('cart_promo') }}"
                        data-label="{{ 'promo.cart.label'|trans }}"
                        data-placeholder="{{ 'promo.cart.placeholder'|trans }}"
                        data-apply-label="{{ 'promo.cart.apply'|trans }}"
                        data-remove-label="{{ 'promo.cart.remove'|trans }}"
                    >
                        {% if cart.promoCode %}
                            <div class="cart-promo__active">
                                <span>
                                    <i class="fa-solid fa-ticket"></i>
                                    <strong>{{ cart.promoCode }}</strong>
                                    <small id="cart-page-active-discount">{{ cart.discountFormatted }}</small>
                                </span>
                                <form action="{{ path('app_front_cart_promo_remove') }}" method="post" data-action="submit->cart#removePromo">
                                    <input type="hidden" name="_csrf_token" value="{{ csrf_token('cart_promo') }}">
                                    <button type="submit" aria-label="{{ 'promo.cart.remove'|trans }}">
                                        <i class="fa-solid fa-xmark"></i>
                                    </button>
                                </form>
                            </div>
                        {% else %}
                            <form action="{{ path('app_front_cart_promo_apply') }}" method="post" class="cart-promo__form" data-action="submit->cart#applyPromo">
                                <input type="hidden" name="_csrf_token" value="{{ csrf_token('cart_promo') }}">
                                <label for="cart-promo-code">{{ 'promo.cart.label'|trans }}</label>
                                <div>
                                    <input id="cart-promo-code" name="promo_code" type="text" required autocomplete="off" placeholder="{{ 'promo.cart.placeholder'|trans }}">
                                    <button type="submit">{{ 'promo.cart.apply'|trans }}</button>
                                </div>
                            </form>
                        {% endif %}
                    </div>
                {% endif %}
                {% if not cart.empty and checkout_form is defined %}
                    {{ form_start(checkout_form, {attr: {
                        class: 'checkout-address-form',
                        'data-turbo': 'false',
                        'data-controller': 'checkout-address'
                    }}) }}
                        <div class="checkout-address-form__heading">
                            <span><i class="fa-solid fa-truck-fast"></i></span>
                            <div>
                                <strong>{{ 'checkout.address.title'|trans }}</strong>
                                <small>{{ checkout_address_saved ? 'checkout.address.saved_text'|trans : 'checkout.address.text'|trans }}</small>
                            </div>
                        </div>

                        {{ form_errors(checkout_form) }}

                        {% if checkout_address_saved and checkout_address %}
                            <article class="checkout-address-card" data-checkout-address-target="card">
                                <span class="checkout-address-card__icon">
                                    <i class="fa-solid fa-location-dot"></i>
                                </span>
                                <address>
                                    <strong>{{ checkout_address.name }}</strong>
                                    <span>{{ checkout_address.street }}</span>
                                    <span>{{ checkout_address.postalCode }} {{ checkout_address.city }}</span>
                                    <small>
                                        {{ checkout_address.countryCode }}
                                        {% if checkout_address.phone %} - {{ checkout_address.phone }}{% endif %}
                                    </small>
                                </address>
                                <button
                                    type="button"
                                    class="checkout-address-card__edit"
                                    data-checkout-address-target="editButton"
                                    data-action="checkout-address#edit"
                                    aria-controls="checkout-address-editor"
                                    aria-expanded="false"
                                    aria-label="{{ 'checkout.address.edit'|trans }}"
                                >
                                    <i class="fa-solid fa-pen"></i>
                                </button>
                            </article>
                        {% endif %}

                        <div
                            id="checkout-address-editor"
                            class="checkout-address-form__editor"
                            data-checkout-address-target="editor"
                            {% if checkout_address_saved %}hidden{% endif %}
                        >
                            <div class="checkout-address-form__field checkout-address-form__field--wide">
                                {{ form_label(checkout_form.name) }}
                                {{ form_widget(checkout_form.name, {attr: {placeholder: 'checkout.address.name_placeholder'|trans}}) }}
                                {{ form_errors(checkout_form.name) }}
                            </div>
                            <div class="checkout-address-form__field checkout-address-form__field--wide">
                                {{ form_label(checkout_form.street) }}
                                {{ form_widget(checkout_form.street, {attr: {placeholder: 'checkout.address.street_placeholder'|trans}}) }}
                                {{ form_errors(checkout_form.street) }}
                            </div>
                            <div class="checkout-address-form__grid">
                                <div class="checkout-address-form__field">
                                    {{ form_label(checkout_form.postalCode) }}
                                    {{ form_widget(checkout_form.postalCode) }}
                                    {{ form_errors(checkout_form.postalCode) }}
                                </div>
                                <div class="checkout-address-form__field">
                                    {{ form_label(checkout_form.city) }}
                                    {{ form_widget(checkout_form.city) }}
                                    {{ form_errors(checkout_form.city) }}
                                </div>
                            </div>
                            <div class="checkout-address-form__field checkout-address-form__field--wide">
                                {{ form_label(checkout_form.phone) }}
                                {{ form_widget(checkout_form.phone, {attr: {placeholder: 'checkout.address.phone_placeholder'|trans}}) }}
                                {{ form_errors(checkout_form.phone) }}
                            </div>

                            {% if checkout_address_saved %}
                                <button
                                    type="button"
                                    class="checkout-address-form__cancel"
                                    data-checkout-address-target="cancelButton"
                                    data-action="checkout-address#cancel"
                                >
                                    <i class="fa-solid fa-arrow-rotate-left"></i>
                                    {{ 'checkout.address.cancel_edit'|trans }}
                                </button>
                            {% endif %}
                        </div>

                        {{ form_widget(checkout_form.countryCode) }}
                        {{ form_rest(checkout_form) }}

                        <button type="submit" class="cart-page__checkout cart-page__checkout--enabled">
                            {{ 'checkout.pay_with_stripe'|trans }}
                            <i class="fa-solid fa-arrow-right"></i>
                        </button>
                        <p class="checkout-address-form__secure">
                            <i class="fa-solid fa-lock"></i>
                            {{ 'checkout.secure_note'|trans }}
                        </p>
                    {{ form_end(checkout_form) }}
                {% else %}
                    <a href="{{ path('app_front_boutique') }}" class="cart-page__checkout cart-page__checkout--enabled">
                        {{ 'overlay.discover_shop'|trans }}
                        <i class="fa-solid fa-arrow-right"></i>
                    </a>
                {% endif %}
            </aside>
        </div>
    </section>
{% endblock %}
