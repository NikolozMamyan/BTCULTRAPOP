{% extends 'emails/base.html.twig' %}

{% block title %}Ton panier ULTRAPOP t’attend{% endblock %}

{% block content %}
    <p style="margin:0 0 8px;color:#e82118;font-size:13px;font-weight:900;text-transform:uppercase;letter-spacing:.08em;">Panier sauvegardé</p>
    <h1 style="margin:0 0 16px;color:#203263;font-size:30px;line-height:1.15;">{{ customer_name }}, ton panier t’attend encore.</h1>
    <p style="margin:0 0 22px;color:#475467;font-size:16px;line-height:1.7;">
        Tu avais repéré quelques produits ULTRAPOP. On les garde au chaud pour que tu puisses reprendre tranquillement ta commande.
    </p>

    {% if products %}
        <table role="presentation" width="100%" cellspacing="0" cellpadding="0" style="margin:0 0 22px;border-collapse:collapse;">
            {% for product in products %}
                <tr>
                    <td style="padding:12px 0;border-bottom:1px solid #eaecf0;color:#203263;font-size:14px;font-weight:800;">
                        {{ product }}
                    </td>
                </tr>
            {% endfor %}
        </table>
    {% endif %}

    <p style="margin:0 0 22px;color:#203263;font-size:18px;font-weight:900;">
        Total estimé : {{ total }}
    </p>

    <a href="{{ cart_url }}" style="display:inline-block;padding:14px 22px;border-radius:999px;background:#e82118;color:#ffffff;text-decoration:none;font-weight:900;">
        Reprendre mon panier
    </a>
{% endblock %}
