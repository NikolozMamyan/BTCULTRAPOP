{% extends 'emails/base.html.twig' %}

{% block title %}Réinitialisation du mot de passe ULTRAPOP{% endblock %}

{% block content %}
    <p style="margin:0 0 8px;color:#e82118;font-size:13px;font-weight:800;text-transform:uppercase;letter-spacing:.08em;">Sécurité du compte</p>
    <h1 style="margin:0 0 18px;font-size:30px;line-height:1.2;">Réinitialiser ton mot de passe</h1>
    <p style="margin:0 0 16px;color:#475467;font-size:16px;line-height:1.7;">
        Bonjour {{ user.firstName }},
    </p>
    <p style="margin:0 0 16px;color:#475467;font-size:16px;line-height:1.7;">
        Nous avons reçu une demande de réinitialisation pour ton compte ULTRAPOP. Ce lien est valable pendant {{ expires_in }} et ne peut être utilisé qu’une seule fois.
    </p>
    <p style="margin:0 0 28px;color:#475467;font-size:16px;line-height:1.7;">
        Si tu n’es pas à l’origine de cette demande, tu peux simplement ignorer cet email.
    </p>
    <a href="{{ reset_url }}" style="display:inline-block;padding:14px 24px;border-radius:999px;background:#e82118;color:#fff;font-weight:800;text-decoration:none;">Choisir un nouveau mot de passe</a>
{% endblock %}
