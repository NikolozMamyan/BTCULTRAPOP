{% set current_route = app.request.attributes.get('_route') %}

<nav class="admin-customer-tabs" aria-label="{{ 'admin.customer.tabs.label'|trans }}">
    <a href="{{ path('app_admin_customers_index') }}" class="{{ current_route == 'app_admin_customers_index' or current_route == 'app_admin_customers_edit' ? 'is-active' : '' }}">
        <i class="fa-solid fa-users"></i>
        {{ 'admin.customer.tabs.customers'|trans }}
    </a>
    <a href="{{ path('app_admin_customers_emailing') }}" class="{{ current_route == 'app_admin_customers_emailing' ? 'is-active' : '' }}">
        <i class="fa-solid fa-envelope-open-text"></i>
        {{ 'admin.customer.tabs.emailing'|trans }}
    </a>
    <a href="{{ path('app_admin_customers_carts') }}" class="{{ current_route starts with 'app_admin_customers_carts' ? 'is-active' : '' }}">
        <i class="fa-solid fa-cart-shopping"></i>
        {{ 'admin.customer.tabs.carts'|trans }}
    </a>
    <a href="{{ path('app_admin_customers_viewer') }}" class="{{ current_route == 'app_admin_customers_viewer' ? 'is-active' : '' }}">
        <i class="fa-solid fa-signal"></i>
        {{ 'admin.customer.tabs.viewer'|trans }}
    </a>
</nav>
