{% extends 'admin/base.html.twig' %}

{% block admin_title %}{{ 'admin.promo.index.title'|trans }}{% endblock %}

{% block admin_content %}
    <section>
        <div class="admin-page-heading admin-page-heading--actions">
            <div>
                <span>{{ 'admin.promo.index.eyebrow'|trans }}</span>
                <h1>{{ 'admin.promo.index.title'|trans }}</h1>
                <p>{{ 'admin.promo.index.subtitle'|trans }}</p>
            </div>
            <a href="{{ path('app_admin_promo_codes_new') }}" class="admin-action-button">
                <i class="fa-solid fa-plus"></i>
                {{ 'admin.promo.index.new'|trans }}
            </a>
        </div>

        <form class="admin-search-bar" method="get" action="{{ path('app_admin_promo_codes_index') }}">
            <label for="admin-promo-search">
                <i class="fa-solid fa-magnifying-glass"></i>
                <span>{{ 'admin.promo.index.search_label'|trans }}</span>
            </label>
            <input id="admin-promo-search" type="search" name="q" value="{{ search }}" placeholder="{{ 'admin.promo.index.search_placeholder'|trans }}">
            <button type="submit">{{ 'admin.promo.index.search_submit'|trans }}</button>
            {% if search %}
                <a href="{{ path('app_admin_promo_codes_index') }}">{{ 'admin.promo.index.reset'|trans }}</a>
            {% endif %}
        </form>

        <article class="admin-panel">
            <div class="admin-panel__heading">
                <div>
                    <span>{{ 'admin.promo.index.list_eyebrow'|trans }}</span>
                    <h2>{{ 'admin.promo.index.list_title'|trans({'%count%': promo_codes|length}) }}</h2>
                </div>
            </div>

            {% if promo_codes %}
                <div class="admin-category-grid">
                    {% for promo in promo_codes %}
                        <article class="admin-category-card">
                            <a href="{{ path('app_admin_promo_codes_edit', {id: promo.id}) }}" class="admin-category-card__main">
                                <span class="admin-category-card__icon"><i class="fa-solid fa-ticket"></i></span>
                                <span>
                                    <em class="admin-category-card__level">{{ promo.active ? 'admin.promo.active.enabled'|trans : 'admin.promo.active.disabled'|trans }}</em>
                                    <strong>{{ promo.code }}</strong>
                                    <small class="admin-category-card__path">
                                        {% if promo.discountType.value == 'percentage' %}
                                            -{{ promo.value|number_format(2, ',', ' ') }} %
                                        {% else %}
                                            -{{ promo.value|number_format(2, ',', ' ') }} €
                                        {% endif %}
                                    </small>
                                    <small>{{ promo.assignedUser ? promo.assignedUser.email : 'admin.promo.index.everyone'|trans }}</small>
                                </span>
                            </a>
                            <div class="admin-category-card__stats">
                                <span>
                                    <strong>{{ promo.usedCount }}</strong>
                                    {{ 'admin.promo.index.used'|trans }}
                                </span>
                                <span>
                                    <strong>{{ promo.maxUses ?: '∞' }}</strong>
                                    {{ 'admin.promo.index.maximum'|trans }}
                                </span>
                            </div>
                            <div class="admin-category-card__footer">
                                <span class="admin-order-badge {{ promo.isAvailableFor(promo.assignedUser) ? 'admin-order-badge--paid' : 'admin-order-badge--cancelled' }}">
                                    {{ promo.isAvailableFor(promo.assignedUser) ? 'admin.promo.index.available'|trans : 'admin.promo.index.unavailable'|trans }}
                                </span>
                                <a href="{{ path('app_admin_promo_codes_edit', {id: promo.id}) }}" class="admin-secondary-button">
                                    <i class="fa-solid fa-pen"></i>
                                    {{ 'admin.promo.action.edit'|trans }}
                                </a>
                            </div>
                        </article>
                    {% endfor %}
                </div>
            {% else %}
                <div class="admin-empty-state">
                    <i class="fa-solid fa-ticket"></i>
                    <p>{{ search ? 'admin.promo.index.no_search_results'|trans : 'admin.promo.index.empty'|trans }}</p>
                    <a href="{{ path('app_admin_promo_codes_new') }}" class="admin-action-button">
                        <i class="fa-solid fa-plus"></i>
                        {{ 'admin.promo.index.new'|trans }}
                    </a>
                </div>
            {% endif %}
        </article>
    </section>
{% endblock %}
